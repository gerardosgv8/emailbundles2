# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_INDUSTRIAL_B2B=price_...

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mailcraft-products

# Site URLs (Vercel API — Stripe success/cancel redirects)
# MUST be your live GitHub Pages URL, not localhost
SITE_URL=https://gerardosgv8.github.io/emailbundles2
ALLOWED_ORIGINS=http://localhost:5174,https://gerardosgv8.github.io

# Download security (Vercel API)
# Days after purchase that download links remain valid (default 7)
DOWNLOAD_ACCESS_DAYS=7
# Max successful downloads per purchase (default 5)
MAX_DOWNLOADS_PER_PURCHASE=5
# Short TTL for each R2 redirect in seconds (default 300 = 5 min)
PRESIGNED_URL_TTL_SECONDS=300
# Legacy — kept for reference; access window uses DOWNLOAD_ACCESS_DAYS
DOWNLOAD_LINK_TTL_SECONDS=86400

# Resend — post-purchase email (https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=Mailcraft Studio <downloads@yourdomain.com>
SUPPORT_EMAIL=support@yourdomain.com
# Published template alias or ID from Resend → Templates (default: mailcraft-studio-intro)
RESEND_PURCHASE_TEMPLATE_ID=mailcraft-studio-intro

# API URL for download links inside purchase emails (Vercel)
API_BASE_URL=https://emailbundles2.vercel.app

# Frontend (Vite) — baked into GitHub Pages at build time (see .env.production)
# VITE_API_URL=https://emailbundles2.vercel.app
