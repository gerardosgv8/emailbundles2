# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_INDUSTRIAL_B2B=price_...

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mailcraft-products

# Site URLs (used for Stripe success/cancel redirects)
# GitHub Pages: include the repo subpath — NOT just the github.io root
SITE_URL=https://gerardosgv8.github.io/emailbundles2
ALLOWED_ORIGINS=http://localhost:5174,https://gerardosgv8.github.io

# Download link TTL (seconds) — default 86400 (24h)
DOWNLOAD_LINK_TTL_SECONDS=86400

# Optional: email delivery via Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Mailcraft Studio <downloads@yourdomain.com>

# Frontend (Vite) — point to your Vercel API when using GitHub Pages for the site
# VITE_API_URL=https://your-project.vercel.app
