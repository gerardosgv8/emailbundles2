{
  "name": "mailcraft-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://gerardosgv8.github.io/emailbundles2",
  "scripts": {
    "dev": "vite",
    "build": "npx tsc --noEmit && npx vite build",
    "vercel-build": "node scripts/vercel-stub-dist.mjs",
    "postinstall": "node scripts/ensure-vite-cli.mjs",
    "build:gh-pages": "npx tsc --noEmit && npx vite build --base=/emailbundles2/ && cp dist/index.html dist/404.html",
    "deploy:gh-pages": "VITE_API_URL=https://emailbundles2.vercel.app npm run deploy",
    "preview": "vite preview",
    "predeploy": "npm run build:gh-pages",
    "deploy": "node scripts/deploy-gh-pages.mjs",
    "dev:api": "vercel dev",
    "verify:templates": "node scripts/verify-bundle-templates.mjs",
    "sync:registry": "node scripts/sync-industrial-bundle-registry.mjs",
    "sync:bundle": "node scripts/sync-industrial-bundle-registry.mjs && node scripts/verify-bundle-templates.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.888.0",
    "gh-pages": "^6.3.0",
    "jszip": "^3.10.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.4",
    "stripe": "^18.5.0",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vercel/node": "^5.3.21"
  }
}
